{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/*.js": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*\\.(html|css|js|json|png|ico|jpg))", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
